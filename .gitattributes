# Normalize line endings on commit; check out native on each platform.
* text=auto eol=lf

# Windows-only files keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf

# Binary - never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
